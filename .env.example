# Talero NT Connect mock — environment template. Copy to .env for local use.

# Server
PORT=8787
NTC_ENV=demo                 # label only: demo | live | staging
TOKEN_SECRET=change-me-to-a-long-random-string

# Datastore backend: local (default, data/db.json) or sheets (Google Sheets)
DATA_BACKEND=local

# --- Required only when DATA_BACKEND=sheets ---
# The spreadsheet id from the Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_IS_THE_SHEET_ID>/edit
SHEET_ID=

# Service-account credentials with edit access to the sheet. Provide ONE of:
#   GOOGLE_SERVICE_ACCOUNT_JSON  = the full JSON (or base64 of it)
#   GOOGLE_SERVICE_ACCOUNT_FILE  = path to the JSON file
GOOGLE_SERVICE_ACCOUNT_JSON=
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
